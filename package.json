    "@types/bun": "1.3.14",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  }
